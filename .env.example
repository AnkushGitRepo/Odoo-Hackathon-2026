# Server environment — copy to server/.env (or project root .env)

# MongoDB connection string — MongoDB Atlas (free tier) or local mongod.
# Atlas format:
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/transitops?retryWrites=true&w=majority"

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET="change-me"

# Optional (defaults shown)
PORT=5000
CLIENT_ORIGIN="http://localhost:5173"
